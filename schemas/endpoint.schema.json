            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finish Reason Path"
        },
        "reasoning_text_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
