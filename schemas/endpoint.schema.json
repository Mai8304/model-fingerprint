        "env_var": {
          "minLength": 1,
          "title": "Env Var",
          "type": "string"
        },
        "kind": {
          "const": "bearer_env",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "env_var"
      ],
      "title": "EndpointAuth",
      "type": "object"
