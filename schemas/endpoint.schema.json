          "type": "boolean"
        },
        "supports_json_object_response": {
          "default": false,
          "title": "Supports Json Object Response",
          "type": "boolean"
        },
        "supports_output_token_cap": {
          "default": true,
          "title": "Supports Output Token Cap",
          "type": "boolean"
        },
        "supports_temperature": {
          "default": true,
          "title": "Supports Temperature",
          "type": "boolean"
        },
        "supports_top_p": {
          "default": true,
          "title": "Supports Top P",
          "type": "boolean"
        }
      },
      "title": "EndpointCapabilities",
      "type": "object"
    },
    "RequestMapping": {
      "additionalProperties": false,
