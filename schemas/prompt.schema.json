{
  "$defs": {
    "GenerationSpec": {
      "additionalProperties": false,
      "properties": {
        "max_output_tokens": {
          "minimum": 1,
          "title": "Max Output Tokens",
          "type": "integer"
        },
        "reasoning_mode": {
          "enum": [
            "ignore",
            "capture_if_available",
            "require_visible"
          ],
          "title": "Reasoning Mode",
          "type": "string"
        },
        "response_format": {
          "enum": [
            "text",
            "json_object"
          ],
          "title": "Response Format",
          "type": "string"
        },
        "temperature": {
          "minimum": 0.0,
          "title": "Temperature",
          "type": "number"
        },
        "top_p": {
          "exclusiveMinimum": 0.0,
          "maximum": 1.0,
          "title": "Top P",
          "type": "number"
        }
      },
      "required": [
        "temperature",
        "top_p",
        "max_output_tokens",
        "response_format",
        "reasoning_mode"
      ],
      "title": "GenerationSpec",
      "type": "object"
    },
    "OutputContract": {
      "additionalProperties": false,
      "properties": {
        "canonicalizer": {
          "pattern": "^[a-z0-9_]+_v[1-9]\\d*$",
          "title": "Canonicalizer",
          "type": "string"
        },
        "id": {
          "pattern": "^[a-z0-9_]+_v[1-9]\\d*$",
          "title": "Id",
          "type": "string"
        }
      },
      "required": [
        "id",
        "canonicalizer"
      ],
      "title": "OutputContract",
      "type": "object"
    },
    "PromptEvaluation": {
      "additionalProperties": false,
      "properties": {
        "reference": {
          "additionalProperties": true,
          "minProperties": 1,
          "title": "Reference",
          "type": "object"
        }
      },
      "required": [
        "reference"
      ],
      "title": "PromptEvaluation",
      "type": "object"
    },
    "PromptExtractors": {
      "additionalProperties": false,
      "properties": {
        "answer": {
          "pattern": "^[a-z_]+_v[1-9]\\d*$",
          "title": "Answer",
          "type": "string"
        },
        "reasoning": {
          "anyOf": [
            {
              "pattern": "^[a-z_]+_v[1-9]\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning"
        },
        "score": {
          "anyOf": [
            {
              "pattern": "^[a-z_]+_v[1-9]\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        },
        "transport": {
          "anyOf": [
            {
              "pattern": "^[a-z_]+_v[1-9]\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transport"
        }
      },
      "required": [
        "answer"
      ],
      "title": "PromptExtractors",
      "type": "object"
    },
    "PromptMessage": {
      "additionalProperties": false,
      "properties": {
        "content": {
          "minLength": 1,
          "title": "Content",
          "type": "string"
        },
        "role": {
          "enum": [
            "system",
            "user",
            "assistant"
          ],
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "role",
        "content"
      ],
      "title": "PromptMessage",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "evaluation": {
      "anyOf": [
        {
          "$ref": "#/$defs/PromptEvaluation"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "extractors": {
      "$ref": "#/$defs/PromptExtractors"
    },
    "family": {
      "enum": [
        "style_brief",
        "strict_format",
        "minimal_diff",
        "structured_extraction",
        "retrieval",
        "evidence_grounding",
        "context_retrieval",
        "abstention",
        "state_tracking",
        "representation_alignment"
      ],
      "title": "Family",
      "type": "string"
    },
    "generation": {
      "$ref": "#/$defs/GenerationSpec"
    },
    "id": {
      "pattern": "^p\\d{3}$",
      "title": "Id",
      "type": "string"
    },
    "intent": {
      "minLength": 1,
      "title": "Intent",
      "type": "string"
    },
    "messages": {
      "items": {
        "$ref": "#/$defs/PromptMessage"
      },
      "minItems": 1,
      "title": "Messages",
      "type": "array"
    },
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "output_contract": {
      "$ref": "#/$defs/OutputContract"
    },
    "required_capabilities": {
      "items": {
        "enum": [
          "chat_completions",
          "json_object_response",
          "visible_reasoning",
          "json_schema_response",
          "function_calling",
          "tool_calling"
        ],
        "type": "string"
      },
      "minItems": 1,
      "title": "Required Capabilities",
      "type": "array"
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "Risk Level",
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "weight_hint": {
      "default": 1.0,
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Weight Hint",
      "type": "number"
    }
  },
  "required": [
    "id",
    "name",
    "family",
    "intent",
    "messages",
    "generation",
    "output_contract",
    "extractors",
    "required_capabilities",
    "risk_level"
  ],
  "title": "PromptDefinition",
  "type": "object"
}
