{
  "$defs": {
    "CanonicalizationEvent": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "minLength": 1,
          "title": "Code",
          "type": "string"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "CanonicalizationEvent",
      "type": "object"
    },
    "CanonicalizedOutput": {
      "additionalProperties": false,
      "properties": {
        "format_id": {
          "minLength": 1,
          "title": "Format Id",
          "type": "string"
        },
        "payload": {
          "additionalProperties": true,
          "title": "Payload",
          "type": "object"
        }
      },
      "required": [
        "format_id"
      ],
      "title": "CanonicalizedOutput",
      "type": "object"
    },
    "CapabilityProbeOutcome": {
      "additionalProperties": false,
      "properties": {
        "detail": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Detail"
        },
        "evidence": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              },
              {
                "type": "string"
              }
            ]
          },
          "title": "Evidence",
          "type": "object"
        },
        "http_status": {
          "anyOf": [
            {
              "maximum": 599,
              "minimum": 100,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Http Status"
        },
        "latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "status": {
          "enum": [
            "supported",
            "accepted_but_ignored",
            "unsupported",
            "insufficient_evidence"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "status"
      ],
      "title": "CapabilityProbeOutcome",
      "type": "object"
    },
    "CapabilityProbeResult": {
      "additionalProperties": false,
      "properties": {
        "capabilities": {
          "additionalProperties": {
            "$ref": "#/$defs/CapabilityProbeOutcome"
          },
          "minProperties": 1,
          "propertyNames": {
            "enum": [
              "thinking",
              "tools",
              "streaming",
              "image"
            ]
          },
          "title": "Capabilities",
          "type": "object"
        },
        "coverage_ratio": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Coverage Ratio",
          "type": "number"
        },
        "probe_mode": {
          "minLength": 1,
          "title": "Probe Mode",
          "type": "string"
        },
        "probe_version": {
          "minLength": 1,
          "title": "Probe Version",
          "type": "string"
        }
      },
      "required": [
        "probe_mode",
        "probe_version",
        "coverage_ratio",
        "capabilities"
      ],
      "title": "CapabilityProbeResult",
      "type": "object"
    },
    "GenerationSpec": {
      "additionalProperties": false,
      "properties": {
        "max_output_tokens": {
          "minimum": 1,
          "title": "Max Output Tokens",
          "type": "integer"
        },
        "reasoning_mode": {
          "enum": [
            "ignore",
            "capture_if_available",
            "require_visible"
          ],
          "title": "Reasoning Mode",
          "type": "string"
        },
        "response_format": {
          "enum": [
            "text",
            "json_object"
          ],
          "title": "Response Format",
          "type": "string"
        },
        "temperature": {
          "minimum": 0.0,
          "title": "Temperature",
          "type": "number"
        },
        "top_p": {
          "exclusiveMinimum": 0.0,
          "maximum": 1.0,
          "title": "Top P",
          "type": "number"
        }
      },
      "required": [
        "temperature",
        "top_p",
        "max_output_tokens",
        "response_format",
        "reasoning_mode"
      ],
      "title": "GenerationSpec",
      "type": "object"
    },
    "NormalizedCompletion": {
      "additionalProperties": false,
      "properties": {
        "answer_text": {
          "default": "",
          "title": "Answer Text",
          "type": "string"
        },
        "finish_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finish Reason"
        },
        "latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "raw_response_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Response Path"
        },
        "reasoning_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Text"
        },
        "reasoning_visible": {
          "default": false,
          "title": "Reasoning Visible",
          "type": "boolean"
        },
        "usage": {
          "$ref": "#/$defs/UsageMetadata"
        }
      },
      "required": [
        "usage"
      ],
      "title": "NormalizedCompletion",
      "type": "object"
    },
    "PromptAttemptSummary": {
      "additionalProperties": false,
      "properties": {
        "answer_text_present": {
          "title": "Answer Text Present",
          "type": "boolean"
        },
        "error_kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Kind"
        },
        "finish_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finish Reason"
        },
        "http_attempt_index": {
          "minimum": 1,
          "title": "Http Attempt Index",
          "type": "integer"
        },
        "http_status": {
          "anyOf": [
            {
              "maximum": 599,
              "minimum": 100,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Http Status"
        },
        "latency_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "output_token_cap": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Token Cap"
        },
        "read_timeout_seconds": {
          "exclusiveMinimum": 0,
          "title": "Read Timeout Seconds",
          "type": "integer"
        },
        "reasoning_visible": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Visible"
        },
        "round_index": {
          "minimum": 1,
          "title": "Round Index",
          "type": "integer"
        },
        "status": {
          "enum": [
            "completed",
            "timeout",
            "transport_error",
            "unsupported_capability",
            "truncated",
            "invalid_response",
            "canonicalization_error"
          ],
          "title": "Status",
          "type": "string"
        },
        "window_index": {
          "minimum": 1,
          "title": "Window Index",
          "type": "integer"
        }
      },
      "required": [
        "round_index",
        "window_index",
        "http_attempt_index",
        "read_timeout_seconds",
        "status",
        "answer_text_present"
      ],
      "title": "PromptAttemptSummary",
      "type": "object"
    },
    "PromptExecutionError": {
      "additionalProperties": false,
      "properties": {
        "http_status": {
          "anyOf": [
            {
              "maximum": 599,
              "minimum": 100,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Http Status"
        },
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "kind",
        "message"
      ],
      "title": "PromptExecutionError",
      "type": "object"
    },
    "PromptMessage": {
      "additionalProperties": false,
      "properties": {
        "content": {
          "minLength": 1,
          "title": "Content",
          "type": "string"
        },
        "role": {
          "enum": [
            "system",
            "user",
            "assistant"
          ],
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "role",
        "content"
      ],
      "title": "PromptMessage",
      "type": "object"
    },
    "PromptRequestSnapshot": {
      "additionalProperties": false,
      "properties": {
        "generation": {
          "$ref": "#/$defs/GenerationSpec"
        },
        "messages": {
          "items": {
            "$ref": "#/$defs/PromptMessage"
          },
          "minItems": 1,
          "title": "Messages",
          "type": "array"
        }
      },
      "required": [
        "messages",
        "generation"
      ],
      "title": "PromptRequestSnapshot",
      "type": "object"
    },
    "PromptRunResult": {
      "additionalProperties": false,
      "properties": {
        "attempts": {
          "items": {
            "$ref": "#/$defs/PromptAttemptSummary"
          },
          "title": "Attempts",
          "type": "array"
        },
        "canonical_output": {
          "anyOf": [
            {
              "$ref": "#/$defs/CanonicalizedOutput"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "canonicalization_events": {
          "items": {
            "$ref": "#/$defs/CanonicalizationEvent"
          },
          "title": "Canonicalization Events",
          "type": "array"
        },
        "completion": {
          "anyOf": [
            {
              "$ref": "#/$defs/NormalizedCompletion"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/PromptExecutionError"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "features": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              },
              {
                "type": "string"
              }
            ]
          },
          "title": "Features",
          "type": "object"
        },
        "prompt_id": {
          "pattern": "^p\\d{3}$",
          "title": "Prompt Id",
          "type": "string"
        },
        "raw_output": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Output"
        },
        "request_snapshot": {
          "anyOf": [
            {
              "$ref": "#/$defs/PromptRequestSnapshot"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status": {
          "default": "completed",
          "enum": [
            "completed",
            "timeout",
            "transport_error",
            "unsupported_capability",
            "truncated",
            "invalid_response",
            "canonicalization_error"
          ],
          "title": "Status",
          "type": "string"
        },
        "usage": {
          "anyOf": [
            {
              "$ref": "#/$defs/UsageMetadata"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "prompt_id"
      ],
      "title": "PromptRunResult",
      "type": "object"
    },
    "ProtocolCompatibility": {
      "additionalProperties": false,
      "properties": {
        "issues": {
          "items": {
            "type": "string"
          },
          "title": "Issues",
          "type": "array"
        },
        "required_capabilities": {
          "items": {
            "type": "string"
          },
          "title": "Required Capabilities",
          "type": "array"
        },
        "satisfied": {
          "title": "Satisfied",
          "type": "boolean"
        }
      },
      "required": [
        "satisfied"
      ],
      "title": "ProtocolCompatibility",
      "type": "object"
    },
    "RuntimePolicySnapshot": {
      "additionalProperties": false,
      "properties": {
        "execution_class": {
          "enum": [
            "thinking",
            "non_thinking"
          ],
          "title": "Execution Class",
          "type": "string"
        },
        "max_rounds": {
          "minimum": 1,
          "title": "Max Rounds",
          "type": "integer"
        },
        "output_token_cap": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Token Cap"
        },
        "policy_id": {
          "minLength": 1,
          "title": "Policy Id",
          "type": "string"
        },
        "round_windows_seconds": {
          "items": {
            "type": "integer"
          },
          "minItems": 1,
          "title": "Round Windows Seconds",
          "type": "array"
        },
        "thinking_probe_status": {
          "enum": [
            "supported",
            "accepted_but_ignored",
            "unsupported",
            "insufficient_evidence"
          ],
          "title": "Thinking Probe Status",
          "type": "string"
        }
      },
      "required": [
        "policy_id",
        "thinking_probe_status",
        "execution_class",
        "round_windows_seconds",
        "max_rounds"
      ],
      "title": "RuntimePolicySnapshot",
      "type": "object"
    },
    "UsageMetadata": {
      "additionalProperties": false,
      "properties": {
        "input_tokens": {
          "minimum": 0,
          "title": "Input Tokens",
          "type": "integer"
        },
        "output_tokens": {
          "minimum": 0,
          "title": "Output Tokens",
          "type": "integer"
        },
        "reasoning_tokens": {
          "default": 0,
          "minimum": 0,
          "title": "Reasoning Tokens",
          "type": "integer"
        },
        "total_tokens": {
          "minimum": 0,
          "title": "Total Tokens",
          "type": "integer"
        }
      },
      "required": [
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "title": "UsageMetadata",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "answer_coverage_ratio": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Answer Coverage Ratio"
    },
    "capability_probe": {
      "anyOf": [
        {
          "$ref": "#/$defs/CapabilityProbeResult"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "claimed_model": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Claimed Model"
    },
    "endpoint_profile_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Endpoint Profile Id"
    },
    "prompt_count_completed": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prompt Count Completed"
    },
    "prompt_count_scoreable": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prompt Count Scoreable"
    },
    "prompt_count_total": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prompt Count Total"
    },
    "prompts": {
      "items": {
        "$ref": "#/$defs/PromptRunResult"
      },
      "minItems": 1,
      "title": "Prompts",
      "type": "array"
    },
    "protocol_compatibility": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProtocolCompatibility"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "reasoning_coverage_ratio": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reasoning Coverage Ratio"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "runtime_policy": {
      "anyOf": [
        {
          "$ref": "#/$defs/RuntimePolicySnapshot"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "suite_id": {
      "pattern": "^(research-set|fingerprint-suite|quick-check)-v[1-9]\\d*$",
      "title": "Suite Id",
      "type": "string"
    },
    "target_label": {
      "minLength": 1,
      "title": "Target Label",
      "type": "string"
    },
    "trace_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Trace Dir"
    }
  },
  "required": [
    "run_id",
    "suite_id",
    "target_label",
    "prompts"
  ],
  "title": "RunArtifact",
  "type": "object"
}
